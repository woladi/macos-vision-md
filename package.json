{
  "name": "macos-vision-md",
  "version": "0.1.0",
  "description": "Convert images to structured Markdown using Apple Vision OCR + local Ollama/Mistral — native, offline, no cloud APIs",
  "author": "Adrian Wolczuk",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/woladi/macos-vision-md.git"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "prepare": "[ -d .git ] && husky || true",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "release": "release-it",
    "release:beta": "release-it --preRelease=beta",
    "eval:setup": "git clone https://github.com/opendataloader-project/opendataloader-bench eval/bench || echo 'bench already cloned'",
    "eval": "tsx eval/eval.ts",
    "eval:report": "tsx eval/report.ts",
    "optimize-prompts": "tsx eval/optimize-prompts.ts"
  },
  "keywords": [
    "ocr",
    "macos",
    "apple-vision",
    "markdown",
    "ollama",
    "mistral",
    "image-to-markdown",
    "llm",
    "document",
    "offline",
    "native"
  ],
  "os": ["darwin"],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "peerDependencies": {
    "macos-vision": "^1.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/node": "^20.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "macos-vision": "^1.0.3",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.9"
  }
}
